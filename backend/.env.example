# Copy to .env and adjust
# APP_NAME=raboo3-ml
# DEBUG=false
# HOST=0.0.0.0
# PORT=8000

# MySQL (Docker: docker compose up -d; then apply db/schema.sql and load dummy data)
MYSQL_ROOT_PASSWORD=raboo3_root
MYSQL_DATABASE=raboo3
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=raboo3_root
# Must match db/schema.sql and scripts/load_dummy_to_mysql.py
DB_NAME=raboo3

# Google Maps (Maps JS / Places / Geocoding) — ضع المفتاح في .env فقط
# GOOGLE_MAPS_API_KEY=

# LLM للتوصية والتقرير (OpenAI) — اختياري؛ بدونه يُعاد تقرير افتراضي
# OPENAI_API_KEY=
